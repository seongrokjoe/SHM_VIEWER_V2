<Window x:Class="ShmViewer.Views.Dialogs.DetailPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShmViewer.Views.Dialogs"
        Title="상세 정보"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="50"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ValueStyle">
            <Setter Property="Foreground" Value="#CE9178"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#444"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <!-- Header -->
            <TextBlock x:Name="HeaderText" FontSize="14" FontWeight="Bold"
                       Foreground="#D4D4D4" FontFamily="Consolas" Margin="0,0,0,10"/>

            <Separator/>

            <!-- Numeric representations -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="DEC" Style="{StaticResource LabelStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DecText" Style="{StaticResource ValueStyle}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="HEX" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HexText" Style="{StaticResource ValueStyle}" Margin="0,4,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="BIN" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="BinText" Style="{StaticResource ValueStyle}"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="OCT" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="OctText" Style="{StaticResource ValueStyle}" Margin="0,4,0,0"/>
            </Grid>

            <Separator/>

            <!-- Type info -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                <TextBlock Text="Offset: " Style="{StaticResource LabelStyle}" Width="Auto" Margin="0,0,4,0"/>
                <TextBlock x:Name="OffsetText" Style="{StaticResource ValueStyle}"/>
                <TextBlock Text="  |  Size: " Style="{StaticResource LabelStyle}" Width="Auto" Margin="0,0,4,0"/>
                <TextBlock x:Name="SizeText" Style="{StaticResource ValueStyle}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Type: " Style="{StaticResource LabelStyle}" Width="Auto" Margin="0,0,4,0"/>
                <TextBlock x:Name="TypeText" Style="{StaticResource ValueStyle}"/>
            </StackPanel>

            <!-- Enum section -->
            <Separator x:Name="EnumSeparator" Visibility="Collapsed"/>
            <TextBlock x:Name="EnumHeader" Text="Enum 값 목록:" Foreground="#DCDCAA"
                       FontFamily="Consolas" FontSize="12" Visibility="Collapsed" Margin="0,0,0,4"/>
            <ItemsControl x:Name="EnumList" Visibility="Collapsed">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}" FontFamily="Consolas" FontSize="12"
                                   FontWeight="{Binding IsCurrent, Converter={x:Static local:BoolToFontWeightConverter.Instance}}"
                                   Foreground="{Binding IsCurrent, Converter={x:Static local:BoolToForegroundConverter.Instance}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Window>
