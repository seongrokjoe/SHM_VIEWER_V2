<Window x:Class="ShmViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShmViewer.ViewModels"
        xmlns:local="clr-namespace:ShmViewer"
        Title="SHM Viewer" Height="750" Width="1100"
        Background="#1E1E1E"
        Drop="Window_Drop" AllowDrop="True"
        DragOver="Window_DragOver">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="DarkBtn">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Button" x:Key="DangerBtn">
            <Setter Property="Background" Value="#6A1212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <!-- Expander toggle button for tree (▶/▼) -->
        <Style x:Key="ExpanderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="16" Height="16">
                            <Path x:Name="Arrow" Fill="#D4D4D4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M 0,0 L 6,4 L 0,8 Z"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Data" Value="M 0,0 L 8,0 L 4,6 Z"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header File Panel ═══ -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#444" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 상단: 헤더 파일 버튼(좌) + 검색(우) -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="헤더 파일" FontWeight="Bold" FontSize="13" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                        <Button Content="+ 파일 추가" Style="{StaticResource DarkBtn}" Margin="10,0,4,0"
                                Command="{Binding AddHeaderFilesCommand}"/>
                        <Button Content="전체 삭제" Style="{StaticResource DangerBtn}" Margin="0,0,10,0"
                                Command="{Binding ClearAllHeaderFilesCommand}"/>
                        <Button Content="🔄 Refresh" Style="{StaticResource DarkBtn}" Margin="0,0,10,0"
                                Command="{Binding RefreshHeadersCommand}"
                                IsEnabled="{Binding CanRefreshHeaders}"
                                ToolTip="Run 중인 SHM Tab이 있을 때는 Refresh할 수 없습니다."/>
                        <TextBlock Text="(헤더 파일을 창에 드래그&amp;드롭하거나 버튼으로 추가)"
                                   Foreground="#666" Margin="0,0,0,0" FontSize="11"/>
                    </StackPanel>

                    <!-- 검색 UI -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBox x:Name="SearchBox" Width="150" Margin="0,0,4,0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="SearchBox_KeyDown"/>
                        <ComboBox Width="100" Margin="0,0,4,0" ItemsSource="{Binding SearchScopeItems, Mode=OneWay}"
                                  SelectedItem="{Binding SelectedSearchScope}"
                                  FontFamily="Consolas" FontSize="11">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <Button Content="검색" Style="{StaticResource DarkBtn}"
                                Command="{Binding SearchCommand}"/>
                    </StackPanel>
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding HeaderFiles, Mode=OneWay}" Margin="0,6,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D2D2D" BorderBrush="#555" BorderThickness="1"
                                    Margin="0,0,6,4" Padding="6,3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📄 " FontSize="11"/>
                                    <TextBlock Text="{Binding Converter={x:Static local:FileNameConverter.Instance}}"
                                               FontSize="11" Foreground="#DCDCAA"/>
                                    <Button Content="✕" Background="Transparent" Foreground="#888"
                                            BorderThickness="0" Padding="4,0,0,0" FontSize="10"
                                            Cursor="Hand" Margin="4,0,0,0"
                                            Command="{Binding DataContext.RemoveHeaderFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Parser Status + 미발견 타입 보기 버튼 -->
        <Border Grid.Row="1" Background="#1E1E1E" Padding="10,4" BorderBrush="#444" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="{Binding ParserStatus}" Foreground="#608B4E" FontSize="11"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="미발견 타입 보기" Style="{StaticResource DarkBtn}" HorizontalAlignment="Right"
                        Command="{Binding ShowLastFailCommand}"
                        Visibility="{Binding HasLastUnresolved, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
            </Grid>
        </Border>

        <!-- ═══ SHM Input ═══ -->
        <Border Grid.Row="2" Background="#252526" Padding="10,8" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="SHM Name :" Width="90"/>
                    <TextBox Width="240" Text="{Binding NewShmName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Struct :" Margin="14,0,0,0" Width="60"/>
                    <TextBox Width="180" Text="{Binding NewStructName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Refresh :" Width="90"/>
                    <RadioButton Content="500ms" GroupName="Refresh"
                                 IsChecked="{Binding NewRefreshMode, Converter={x:Static local:EnumToBoolConverter.Instance}, ConverterParameter=Ms500}"/>
                    <RadioButton Content="1s" GroupName="Refresh"
                                 IsChecked="{Binding NewRefreshMode, Converter={x:Static local:EnumToBoolConverter.Instance}, ConverterParameter=Ms1000}"/>
                    <RadioButton Content="5s" GroupName="Refresh"
                                 IsChecked="{Binding NewRefreshMode, Converter={x:Static local:EnumToBoolConverter.Instance}, ConverterParameter=Ms5000}"/>
                    <RadioButton Content="수동" GroupName="Refresh"
                                 IsChecked="{Binding NewRefreshMode, Converter={x:Static local:EnumToBoolConverter.Instance}, ConverterParameter=Manual}"/>
                    <Button Content="Load" Style="{StaticResource DarkBtn}" Margin="20,0,6,0"
                            Command="{Binding LoadShmTabCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Tab Area ═══ -->
        <TabControl Grid.Row="3" Background="#1E1E1E" BorderBrush="#444"
                    ItemsSource="{Binding Tabs, Mode=OneWay}"
                    SelectedItem="{Binding SelectedTab}">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ShmTabViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TabTitle}" Foreground="Black"
                                   FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="✕" Background="Transparent" Foreground="#888"
                                BorderThickness="0" Padding="6,0,0,0" FontSize="10"
                                Cursor="Hand" Margin="4,0,0,0"
                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:ShmTabViewModel}">
                    <Grid Background="#1E1E1E">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Status bar -->
                        <Border Grid.Row="0" Background="#252526" Padding="10,5"
                                BorderBrush="#444" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusText}" FontSize="12"
                                           Foreground="{Binding IsStatusError, Converter={x:Static local:BoolToErrorColorConverter.Instance}}"/>
                                <TextBlock Text="  |  마지막 갱신: " Foreground="#666" FontSize="11" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding LastRefreshTime}" Foreground="#666" FontSize="11"/>
                                <Button Content="Run" Style="{StaticResource DarkBtn}" Margin="20,0,6,0"
                                        Command="{Binding RunCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={x:Static local:InverseBoolConverter.Instance}}"
                                        Visibility="{Binding CanRun, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                                <Button Content="Stop" Style="{StaticResource DangerBtn}" Margin="20,0,6,0"
                                        Command="{Binding StopCommand}"
                                        Visibility="{Binding IsRunning, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                                <Button Content="Refresh" Style="{StaticResource DarkBtn}"
                                        Command="{Binding ManualRefreshCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={x:Static local:InverseBoolConverter.Instance}}"
                                        Visibility="{Binding IsManualMode, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                                <Button Content="자세히 보기" Style="{StaticResource DarkBtn}" Margin="10,0,0,0"
                                        Command="{Binding ShowUnresolvedCommand}"
                                        Visibility="{Binding HasUnresolvedTypes, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Tree -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Column Header with GridSplitters -->
                            <Border Grid.Row="0" Background="#2D2D2D" Padding="4,4,4,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding DataContext.Col0Width, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="{Binding DataContext.Col1Width, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="{Binding DataContext.Col2Width, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SIZE (+offset)" Foreground="#9CDCFE" FontWeight="Bold"/>
                                    <GridSplitter x:Name="Splitter0" Grid.Column="1" HorizontalAlignment="Stretch" Background="#444" Cursor="SizeWE"
                                                  PreviewMouseLeftButtonDown="GridSplitter_PreviewMouseDown" PreviewMouseMove="GridSplitter_PreviewMouseMove"/>
                                    <TextBlock Grid.Column="2" Text="TYPE" Foreground="#9CDCFE" FontWeight="Bold" Margin="4,0,0,0"/>
                                    <GridSplitter x:Name="Splitter1" Grid.Column="3" HorizontalAlignment="Stretch" Background="#444" Cursor="SizeWE"
                                                  PreviewMouseLeftButtonDown="GridSplitter_PreviewMouseDown" PreviewMouseMove="GridSplitter_PreviewMouseMove"/>
                                    <TextBlock Grid.Column="4" Text="NAME" Foreground="#9CDCFE" FontWeight="Bold" Margin="4,0,0,0"/>
                                    <GridSplitter x:Name="Splitter2" Grid.Column="5" HorizontalAlignment="Stretch" Background="#444" Cursor="SizeWE"
                                                  PreviewMouseLeftButtonDown="GridSplitter_PreviewMouseDown" PreviewMouseMove="GridSplitter_PreviewMouseMove"/>
                                    <TextBlock Grid.Column="6" Text="VALUE" Foreground="#9CDCFE" FontWeight="Bold" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- TreeView -->
                            <TreeView Grid.Row="1" ItemsSource="{Binding RootNodes, Mode=OneWay}"
                                      Background="#1E1E1E" BorderThickness="0"
                                      x:Name="ShmTree"
                                      MouseRightButtonUp="TreeView_MouseRightButtonUp"
                                      PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      VirtualizingStackPanel.ScrollUnit="Pixel">
                                <TreeView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </TreeView.ItemsPanel>
                                <TreeView.Resources>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#D4D4D4"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
                                        <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TreeViewItem">
                                                    <StackPanel>
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                Padding="2,1">
                                                            <ContentPresenter x:Name="PART_Header"
                                                                              ContentSource="Header"
                                                                              HorizontalAlignment="Stretch"/>
                                                        </Border>
                                                        <ItemsPresenter x:Name="ItemsHost" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsExpanded" Value="True">
                                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#264F78"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="Background" Value="#264F78"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.Resources>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}"
                                                              ItemsSource="{Binding Children, Mode=OneWay}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding DataContext.Col0Width, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="{Binding DataContext.Col1Width, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="{Binding DataContext.Col2Width, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Column 0: SIZE (+offset) -->
                                            <TextBox Grid.Column="0" Text="{Binding SizeDisplay, Mode=OneWay}" IsReadOnly="True"
                                                     Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#333" IsTabStop="False"
                                                     FontFamily="Consolas" FontSize="12" Padding="0" Margin="0"
                                                     Foreground="#B5CEA8"/>
                                            <Border Grid.Column="1"/>
                                            <!-- Column 2: TYPE (with tree expander + level indent) -->
                                            <Border Grid.Column="2" BorderThickness="0,0,1,0" BorderBrush="#333">
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="{Binding Level, Converter={x:Static local:LevelToMarginConverter.Instance}}">
                                                    <ToggleButton Style="{StaticResource ExpanderToggleStyle}"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                                                  Visibility="{Binding HasChildren, Converter={x:Static local:BoolToVisConverter.Instance}}"/>
                                                    <TextBox Text="{Binding TypeName}" IsReadOnly="True"
                                                             Background="Transparent" BorderThickness="0" IsTabStop="False"
                                                             FontFamily="Consolas" FontSize="12" Padding="0" Margin="0"
                                                             Foreground="#4EC9B0"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="3"/>
                                            <!-- Column 4: NAME -->
                                            <TextBox Grid.Column="4" Text="{Binding Name}" IsReadOnly="True"
                                                     Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#333" IsTabStop="False"
                                                     FontFamily="Consolas" FontSize="12" Padding="0" Margin="0"
                                                     Foreground="{Binding IsSpare, Converter={x:Static local:SpareColorConverter.Instance}}"/>
                                            <Border Grid.Column="5"/>
                                            <!-- Column 6: VALUE -->
                                            <TextBox Grid.Column="6" Text="{Binding Value}" IsReadOnly="True"
                                                     Background="Transparent" BorderThickness="0" IsTabStop="False"
                                                     FontFamily="Consolas" FontSize="12" Padding="0" Margin="0"
                                                     Foreground="{Binding IsSpare, Converter={x:Static local:SpareColorConverter.Instance}}"/>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <Border Grid.RowSpan="2"
                                    Panel.ZIndex="10"
                                    Background="#66000000"
                                    Cursor="Wait"
                                    Visibility="{Binding IsInputBlocked, Converter={x:Static local:BoolToVisConverter.Instance}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ProgressBar Width="180" Height="8" IsIndeterminate="True" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding BusyMessage}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="잠시만 기다려주세요..." FontSize="11" Foreground="#D4D4D4" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- ═══ 검색 결과 패널 (Expander) ═══ -->
        <Expander Grid.Row="4" Header="검색 결과" IsExpanded="{Binding IsSearchExpanded}"
                  Background="#1E1E1E" BorderBrush="#444" BorderThickness="0,1,0,0">
            <Grid Background="#1E1E1E">
                <DataGrid x:Name="SearchResultGrid"
                          ItemsSource="{Binding SearchResults}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="#1E1E1E"
                          Foreground="#D4D4D4"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#333"
                          BorderThickness="0"
                          RowBackground="#1E1E1E"
                          AlternatingRowBackground="#252526"
                          HeadersVisibility="Column"
                          CanUserResizeRows="False"
                          Height="200"
                          FontFamily="Consolas"
                          FontSize="11"
                          MouseDoubleClick="SearchResult_DoubleClick">
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <Expander IsExpanded="True" Background="#1E1E1E">
                                                    <Expander.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" Foreground="#9CDCFE"
                                                                       FontWeight="Bold" FontFamily="Consolas" FontSize="12"/>
                                                            <TextBlock Text=" (" Foreground="#888" FontFamily="Consolas" FontSize="11"/>
                                                            <TextBlock Text="{Binding ItemCount}" Foreground="#888" FontFamily="Consolas" FontSize="11"/>
                                                            <TextBlock Text="건)" Foreground="#888" FontFamily="Consolas" FontSize="11"/>
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <ItemsPresenter/>
                                                </Expander>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </DataGrid.GroupStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="Foreground" Value="#9CDCFE"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="BorderBrush" Value="#444"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Foreground" Value="#D4D4D4"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TAB" Binding="{Binding TabName}" Width="100"/>
                        <DataGridTextColumn Header="경로" Binding="{Binding NodePath}" Width="*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding TypeName}" Width="120"/>
                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Expander>

        <Border Grid.Row="5" Background="#252526" BorderBrush="#444" BorderThickness="0,1,0,0" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="SHM_Viewer_v1.0_20260310 / 동작 전 struct 크기 확인 필수...!!"
                           HorizontalAlignment="Left"
                           Foreground="#DCDCAA"/>
                <TextBlock Grid.Column="1"
                           Text="Bug Report : sr.joe"
                           HorizontalAlignment="Right"
                           Foreground="#9CDCFE"/>
            </Grid>
        </Border>
    </Grid>
</Window>
